        "    day_str = dt.strftime('%Y-%m-%d')\n",
        "    if day_str not in days_active[m['sender']]:\n",
        "        days_active[m['sender']].append(day_str)\n",
        "\n",
        "# finding the longest silent streak for each person\n",
        "# a streak is consecutive days with zero messages\n",
        "longest_streak = {}\n",
        "for sender in sorted_senders:\n",
        "    active_days_set = days_active[sender]\n",
        "    all_days_in_range = []\n",
        "    current_day = first_date\n",
        "    while current_day <= last_date:\n",
        "        all_days_in_range.append(current_day.strftime('%Y-%m-%d'))\n",
        "        current_day = current_day + timedelta(days=1)\n",
        "    max_streak = 0\n",
        "    current_streak = 0\n",
        "    for day in all_days_in_range:\n",
        "        if day not in active_days_set:\n",
        "            current_streak = current_streak + 1\n",
        "            if current_streak > max_streak:\n",
        "                max_streak = current_streak\n",
        "        else:\n",
        "            current_streak = 0\n",
        "    longest_streak[sender] = max_streak\n",
        "\n",
        "streaks_sorted = sorted(sorted_senders, key=lambda x: longest_streak[x], reverse=True)\n",
        "\n",
        "print('=' * 60)\n",
