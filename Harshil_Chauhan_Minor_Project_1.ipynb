      "source": [
        "# each function below checks one archetype and returns a score\n",
        "# the higher the score the more that person fits that archetype\n",
        "\n",
        "def get_spammer_score(sender, all_messages):\n",
        "    # counting how many messages in a row this person tends to send\n",
        "    burst_lengths = []\n",
        "    current_burst = 1\n",
        "    for i in range(1, len(all_messages)):\n",
        "        if all_messages[i]['sender'] == sender and all_messages[i-1]['sender'] == sender:\n",
        "            current_burst = current_burst + 1\n",
        "        elif all_messages[i-1]['sender'] == sender:\n",
        "            burst_lengths.append(current_burst)\n",
        "            current_burst = 1\n",
        "    if len(burst_lengths) == 0:\n",
        "        return 0\n",
        "    total = 0\n",
        "    for b in burst_lengths:\n",
        "        total = total + b\n",
        "    return total / len(burst_lengths)\n",
        "\n",
        "def get_group_mom_score(sender, all_messages):\n",
        "    # counting how many times this person uses caring words\n",
        "    caring_words = ['okay', 'safe', 'eat', 'sleep', 'take care', 'are you', 'please',\n",
        "                    'reminder', 'drink water', \"don't forget\", 'doing okay', 'feel better']\n",
        "    count = 0\n",
        "    for m in all_messages:\n",
        "        if m['sender'] == sender:\n",
        "            text = m['text'].lower()\n",
        "            for word in caring_words:\n",
        "                if word in text:\n",
        "                    count = count + 1\n",
        "    return count\n",
        "\n",
        "def get_night_owl_score(sender, heatmap_matrix, person_idx):\n",
        "    # checking what fraction of their messages were sent between 11pm and 5am\n",
        "    row = heatmap_matrix[person_idx]\n",
        "    night_hours = list(range(23, 24)) + list(range(0, 5))\n",
        "    night_msgs = 0\n",
        "    for h in night_hours:\n",
        "        night_msgs = night_msgs + row[h]\n",
        "    total = row.sum()\n",
        "    if total == 0:\n",
        "        return 0\n",
        "    return night_msgs / total\n",
        "\n",
        "def get_storyteller_score(sender, all_messages):\n",
        "    # average number of words per message, longer messages = storyteller\n",
        "    total_words = 0\n",
        "    msg_count = 0\n",
        "    for m in all_messages:\n",
        "        if m['sender'] == sender:\n",
        "            total_words = total_words + len(m['text'].split())\n",
        "            msg_count = msg_count + 1\n",
        "    if msg_count == 0:\n",
        "        return 0\n",
        "    return total_words / msg_count\n",
        "\n",
        "def get_drama_queen_score(sender, all_messages):\n",
        "    # checking how many of their messages are all caps or have 2+ exclamation marks\n",
        "    caps_count = 0\n",
        "    eligible = 0\n",
        "    for m in all_messages:\n",
        "        if m['sender'] == sender:\n",
        "            text = m['text']\n",
        "            if len(text) < 3:\n",
        "                continue\n",
        "            eligible = eligible + 1\n",
        "            alpha_chars = ''\n",
        "            for c in text:\n",
        "                if c.isalpha():\n",
        "                    alpha_chars = alpha_chars + c\n",
        "            if len(alpha_chars) > 0 and alpha_chars.isupper():\n",
        "                caps_count = caps_count + 1\n",
        "            elif text.count('!') >= 2:\n",
        "                caps_count = caps_count + 1\n",
        "    if eligible == 0:\n",
        "        return 0\n",
        "    return caps_count / eligible\n",
        "\n",
        "def get_ghost_score(sender, days_active_dict, total_days_count):\n",
        "    # fraction of days they were completely silent\n",
        "    active_count = len(days_active_dict[sender])\n",
        "    silent_count = total_days_count - active_count\n",
        "    return silent_count / total_days_count\n",
        "\n",
        "def get_comedian_score(sender, all_messages):\n",
        "    # what fraction of their messages have laugh words in them\n",
        "    laugh_words = ['lol', 'lmao', 'haha', 'rofl', 'lmfao', 'hahaha', 'hehe']\n",
        "    count = 0\n",
        "    total = 0\n",
        "    for m in all_messages:\n",
        "        if m['sender'] == sender:\n",
        "            total = total + 1\n",
        "            text = m['text'].lower()\n",
        "            for w in laugh_words:\n",
        "                if w in text:\n",
        "                    count = count + 1\n",
        "                    break\n",
        "    if total == 0:\n",
        "        return 0\n",
        "    return count / total\n",
        "\n",
        "def get_question_master_score(sender, all_messages):\n",
        "    # how many of their messages end with a question mark\n",
        "    q_count = 0\n",
        "    total = 0\n",
        "    for m in all_messages:\n",
        "        if m['sender'] == sender:\n",
        "            total = total + 1\n",
        "            if m['text'].strip().endswith('?'):\n",
        "                q_count = q_count + 1\n",
        "    if total == 0:\n",
        "        return 0\n",
        "    return q_count / total\n",
        "\n",
        "# computing scores for every person for every archetype\n",
        "archetype_scores = {}\n",
        "for sender in sorted_senders:\n",
        "    idx = person_index[sender]\n",
        "    scores = {}\n",
        "    # dividing by big numbers so all scores are between 0 and 1 roughly\n",
        "    scores['THE SPAMMER'] = get_spammer_score(sender, real_messages) / 10.0\n",
        "    scores['THE GROUP MOM'] = get_group_mom_score(sender, real_messages) / 300.0\n",
        "    scores['THE NIGHT OWL'] = get_night_owl_score(sender, heatmap, idx)\n",
        "    scores['THE STORYTELLER'] = get_storyteller_score(sender, real_messages) / 100.0\n",
        "    scores['THE DRAMA QUEEN'] = get_drama_queen_score(sender, real_messages)\n",
        "    scores['THE GHOST'] = get_ghost_score(sender, days_active, total_days)\n",
        "    scores['THE COMEDIAN'] = get_comedian_score(sender, real_messages)\n",
        "    scores['THE QUESTION MASTER'] = get_question_master_score(sender, real_messages)\n",
        "    archetype_scores[sender] = scores\n",
        "\n",
        "# assigning whoever has the highest score in each archetype to that archetype\n",
        "assigned_archetypes = {}\n",
        "for sender in sorted_senders:\n",
        "    scores = archetype_scores[sender]\n",
        "    best_archetype = None\n",
        "    best_score = -1\n",
        "    for archetype in scores:\n",
        "        if scores[archetype] > best_score:\n",
        "            best_score = scores[archetype]\n",
        "            best_archetype = archetype\n",
        "    assigned_archetypes[sender] = best_archetype\n",
        "\n",
        "# making a short description line for each person based on their archetype\n",
        "archetype_details = {}\n",
        "for sender in sorted_senders:\n",
        "    idx = person_index[sender]\n",
        "    archetype = assigned_archetypes[sender]\n",
        "    if archetype == 'THE SPAMMER':\n",
        "        detail = 'avg ' + str(round(get_spammer_score(sender, real_messages), 1)) + ' msgs in a row'\n",
        "    elif archetype == 'THE GROUP MOM':\n",
        "        detail = 'caring keyword score: ' + str(get_group_mom_score(sender, real_messages))\n",
        "    elif archetype == 'THE NIGHT OWL':\n",
        "        pct = round(get_night_owl_score(sender, heatmap, idx) * 100, 1)\n",
        "        detail = str(pct) + '% msgs between 23h-04h'\n",
        "    elif archetype == 'THE STORYTELLER':\n",
        "        detail = 'avg ' + str(round(get_storyteller_score(sender, real_messages), 1)) + ' words per msg'\n",
        "    elif archetype == 'THE DRAMA QUEEN':\n",
        "        pct = round(get_drama_queen_score(sender, real_messages) * 100, 1)\n",
        "        detail = str(pct) + '% ALL-CAPS messages'\n",
        "    elif archetype == 'THE GHOST':\n",
        "        pct = round(get_ghost_score(sender, days_active, total_days) * 100, 1)\n",
        "        detail = 'silent ' + str(pct) + '% of days'\n",
        "    elif archetype == 'THE COMEDIAN':\n",
        "        pct = round(get_comedian_score(sender, real_messages) * 100, 1)\n",
        "        detail = str(pct) + '% msgs with laugh words'\n",
        "    elif archetype == 'THE QUESTION MASTER':\n",
        "        pct = round(get_question_master_score(sender, real_messages) * 100, 1)\n",
        "        detail = str(pct) + '% msgs end with ?'\n",
        "    else:\n",
