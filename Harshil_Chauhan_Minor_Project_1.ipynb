      "source": [
        "## Feature 1: Chat Parser"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "a148fa62",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "a148fa62",
        "outputId": "4b138c76-4daf-434c-cd7b-77573582a260"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Successfully parsed 3127 messages from 6 participants\n",
            "Skipped 4 system messages, 32 media-omitted, 15 deleted messages\n"
          ]
        }
      ],
      "source": [
        "# i need to import datetime to work with times later\n",
        "# and numpy for the heatmap thing\n",
        "from datetime import datetime, timedelta\n",
        "import numpy as np\n",
        "\n",
        "# opening the file and reading everything inside it\n",
        "fnme=input("File Address/Name:")\n"
        "with open(fnme, 'r') as f:\n",
        "    content = f.read()\n",
        "\n",
        "# splitting the big string into a list of lines\n",
        "lines = content.split('\\n')\n",
        "\n",
        "# this list will hold all the messages i find\n",
        "messages = []\n",
        "\n",
        "# keeping count of the weird lines i want to skip\n",
        "system_count = 0\n",
        "media_count = 0\n",
        "deleted_count = 0\n",
        "\n",
        "# tracking how many media and deleted messages each person sent\n",
        "media_per_person = {}\n",
        "deleted_per_person = {}\n",
        "\n",
        "# i need this to handle messages that span multiple lines\n",
        "previous_message_index = -1\n",
        "\n",
        "for line in lines:\n",
        "    line = line.strip()\n",
        "\n",
        "    # skip blank lines\n",
        "    if line == '':\n",
        "        continue\n",
        "\n",
        "    # if the line is too short it cant be a real message\n",
        "    if len(line) < 8:\n",
        "        if previous_message_index >= 0:\n",
        "            messages[previous_message_index]['text'] = messages[previous_message_index]['text'] + ' ' + line\n",
        "        continue\n",
        "\n",
        "    # checking if the line starts with a date like 01/04/24\n",
        "    first_eight = line[:8]\n",
        "    is_date_start = first_eight[2] == '/' and first_eight[5] == '/'\n",
        "\n",
        "    # if it doesnt start with a date its a continuation of the previous message\n",
        "    if not is_date_start:\n",
        "        if previous_message_index >= 0:\n",
        "            messages[previous_message_index]['text'] = messages[previous_message_index]['text'] + ' ' + line\n",
        "        continue\n",
        "\n",
        "    # every real line should have ' - ' to separate timestamp from the rest\n",
        "    if ' - ' not in line:\n",
        "        continue\n",
        "\n",
        "    # splitting into timestamp and everything after the dash\n",
        "    parts = line.split(' - ', 1)\n",
        "    timestamp_str = parts[0].strip()\n",
        "    rest = parts[1].strip()\n",
        "\n",
        "    # system messages dont have a colon after the sender name\n",
        "    if ': ' not in rest:\n",
        "        system_count = system_count + 1\n",
        "        continue\n",
        "\n",
        "    # now splitting sender name from the actual message text\n",
        "    sender_and_message = rest.split(': ', 1)\n",
        "    sender = sender_and_message[0].strip()\n",
        "    text = sender_and_message[1].strip()\n",
        "\n",
        "    # checking if it was a media file that got omitted\n",
        "    if text == '<Media omitted>':\n",
        "        if sender not in media_per_person:\n",
        "            media_per_person[sender] = 0\n",
        "        media_per_person[sender] = media_per_person[sender] + 1\n",
        "        media_count = media_count + 1\n",
        "        msg = {'timestamp': timestamp_str, 'sender': sender, 'text': text, 'is_media': True, 'is_deleted': False}\n",
        "        messages.append(msg)\n",
        "        previous_message_index = len(messages) - 1\n",
        "        continue\n",
        "\n",
        "    # checking if the person deleted this message\n",
        "    if text == 'This message was deleted':\n",
        "        if sender not in deleted_per_person:\n",
        "            deleted_per_person[sender] = 0\n",
        "        deleted_per_person[sender] = deleted_per_person[sender] + 1\n",
        "        deleted_count = deleted_count + 1\n",
        "        msg = {'timestamp': timestamp_str, 'sender': sender, 'text': text, 'is_media': False, 'is_deleted': True}\n",
        "        messages.append(msg)\n",
        "        previous_message_index = len(messages) - 1\n",
        "        continue\n",
        "\n",
        "    # this is a normal real message so i store it\n",
        "    msg = {'timestamp': timestamp_str, 'sender': sender, 'text': text, 'is_media': False, 'is_deleted': False}\n",
        "    messages.append(msg)\n",
        "    previous_message_index = len(messages) - 1\n",
        "\n",
        "# keeping only the real messages for analysis, skipping media and deleted\n",
        "real_messages = []\n",
        "for m in messages:\n",
        "    if not m['is_media'] and not m['is_deleted']:\n",
        "        real_messages.append(m)\n",
        "\n",
        "# finding out who all the senders are\n",
        "all_senders = []\n",
        "for m in real_messages:\n",
        "    if m['sender'] not in all_senders:\n",
        "        all_senders.append(m['sender'])\n",
        "\n",
        "print('Successfully parsed', len(real_messages), 'messages from', len(all_senders), 'participants')\n",
        "print('Skipped', system_count, 'system messages,', media_count, 'media-omitted,', deleted_count, 'deleted messages')\n",
        "#I had a hard time understanding how this worked, and took help from various sources including ai to do this part."
      ]
    },
