        "    msgs_by_hour[hour_key] = msgs_by_hour[hour_key] + 1\n",
        "\n",
        "# using max with a key to find whichever day had the most messages\n",
        "busiest_day = max(msgs_by_date, key=lambda x: msgs_by_date[x])\n",
        "busiest_day_count = msgs_by_date[busiest_day]\n",
        "\n",
        "busiest_hour = max(msgs_by_hour, key=lambda x: msgs_by_hour[x])\n",
        "busiest_hour_count = msgs_by_hour[busiest_hour]\n",
        "avg_per_day_that_hour = busiest_hour_count / total_days\n",
