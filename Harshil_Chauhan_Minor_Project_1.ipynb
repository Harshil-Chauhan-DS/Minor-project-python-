            "how            ████████████████████   321\n",
            "guys           ███████████████████    318\n",
            "hai            ████████████████       268\n",
            "am             ████████████████       260\n",
            "today          ████████████████       257\n",
            "which          ████████████           202\n",
            "everyone       ███████████            187\n",
            "telling        ███████████            179\n",
            "bhai           █████████              160\n",
            "one            █████████              157\n",
            "\n",
            "TOP WORD PER PERSON\n",
            "------------------------------------------------------------\n",
            "Rahul      : hai (263 times)\n",
            "Priya      : please (141 times)\n",
            "Neha       : am (148 times)\n",
            "Aman       : am (98 times)\n",
            "Karan      : how (295 times)\n",
            "Vikas      : hai (5 times)\n"
          ]
        }
      ],
      "source": [
        "# these are really common words that dont tell us anything interesting\n",
        "stop_words = ['i', 'is', 'the', 'a', 'and', 'or', 'to', 'of', 'in', 'on', 'for',\n",
        "              'it', 'me', 'my', 'you', 'he', 'she', 'we', 'they', 'this', 'that',\n",
        "              'but', 'are', 'was', 'be', 'been', 'have', 'has', 'do', 'did', 'not',\n",
        "              'with', 'so', 'at', 'by', 'from', 'up', 'about', 'into', 'then',\n",
        "              'its', 'also', 'as', 'an', 'if', 'no', 'just', 'will', 'get', 'got',\n",
        "              'can', 'all', 'out', 'what', 'your', 'his', 'her', 'their', 'our']\n",
        "\n",
        "# this dict will store how many times each word appears\n",
        "word_counts = {}\n",
        "\n",
        "for m in real_messages:\n",
        "    # lowercase so Bhai and bhai count as the same word\n",
        "    text = m['text'].lower()\n",
        "    raw_words = text.split()\n",
        "    for word in raw_words:\n",
        "        # removing punctuation from the start and end of the word\n",
        "        cleaned = word\n",
        "        while len(cleaned) > 0 and not cleaned[0].isalpha():\n",
        "            cleaned = cleaned[1:]\n",
        "        while len(cleaned) > 0 and not cleaned[-1].isalpha():\n",
        "            cleaned = cleaned[:-1]\n",
        "        if cleaned == '':\n",
        "            continue\n",
        "        if cleaned in stop_words:\n",
        "            continue\n",
        "        # skipping single characters like 'k' or 'n'\n",
        "        if len(cleaned) < 2:\n",
        "            continue\n",
        "        if cleaned not in word_counts:\n",
        "            word_counts[cleaned] = 0\n",
        "        word_counts[cleaned] = word_counts[cleaned] + 1\n",
        "\n",
        "# sorting all words by count and taking the top 10\n",
        "sorted_words = sorted(word_counts, key=lambda x: word_counts[x], reverse=True)\n",
        "top_words = sorted_words[:10]\n",
        "max_word_count = word_counts[top_words[0]]\n",
        "\n",
        "print('=' * 60)\n",
        "print(\"THIS GROUP'S FAVOURITE WORDS\")\n",
        "print('=' * 60)\n",
        "# the bar length is proportional to how often the word appears\n",
        "for word in top_words:\n",
        "    count = word_counts[word]\n",
        "    bar_len = int((count / max_word_count) * 20)\n",
        "    bar = chr(9608) * bar_len\n",
        "    print(word.ljust(14) + ' ' + bar.ljust(22) + ' ' + str(count))\n",
        "\n",
        "print()\n",
        "# also showing per person what their most used word is\n",
        "print('TOP WORD PER PERSON')\n",
        "print('-' * 60)\n",
        "for sender in sorted_senders:\n",
        "    person_word_counts = {}\n",
        "    for m in real_messages:\n",
        "        if m['sender'] == sender:\n",
        "            text = m['text'].lower()\n",
        "            raw_words = text.split()\n",
        "            for word in raw_words:\n",
        "                cleaned = word\n",
        "                while len(cleaned) > 0 and not cleaned[0].isalpha():\n",
        "                    cleaned = cleaned[1:]\n",
        "                while len(cleaned) > 0 and not cleaned[-1].isalpha():\n",
        "                    cleaned = cleaned[:-1]\n",
        "                if cleaned == '' or cleaned in stop_words or len(cleaned) < 2:\n",
        "                    continue\n",
        "                if cleaned not in person_word_counts:\n",
        "                    person_word_counts[cleaned] = 0\n",
        "                person_word_counts[cleaned] = person_word_counts[cleaned] + 1\n",
        "    if len(person_word_counts) > 0:\n",
        "        top_word = max(person_word_counts, key=lambda x: person_word_counts[x])\n",
        "        print(sender.ljust(10) + ' : ' + top_word + ' (' + str(person_word_counts[top_word]) + ' times)')\n"
      ]
