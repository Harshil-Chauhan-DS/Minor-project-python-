      "source": [
        "# making two dicts, one for daily counts and one for hourly counts\n",
        "msgs_by_date = {}\n",
        "msgs_by_hour = {}\n",
        "\n",
        "for m in real_messages:\n",
        "    dt = datetime.strptime(m['timestamp'], '%d/%m/%y, %H:%M')\n",
        "    date_key = dt.strftime('%d %B %Y')\n",
        "    hour_key = dt.hour\n",
        "\n",
        "    if date_key not in msgs_by_date:\n",
        "        msgs_by_date[date_key] = 0\n",
        "    msgs_by_date[date_key] = msgs_by_date[date_key] + 1\n",
        "\n",
