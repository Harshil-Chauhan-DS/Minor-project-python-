        "# storing the time gaps (in seconds) for each person when they replied\n",
        "response_gaps = {}\n",
        "for sender in sorted_senders:\n",
        "    response_gaps[sender] = []\n",
        "\n",
        "# going through every message and checking how long it took to reply\n",
        "for i in range(1, len(real_messages)):\n",
        "    current_msg = real_messages[i]\n",
        "    previous_msg = real_messages[i - 1]\n",
        "\n",
        "    # not counting it as a reply if the same person sent both messages\n",
        "    if current_msg['sender'] == previous_msg['sender']:\n",
        "        continue\n",
        "\n",
        "    current_time = datetime.strptime(current_msg['timestamp'], '%d/%m/%y, %H:%M')\n",
        "    previous_time = datetime.strptime(previous_msg['timestamp'], '%d/%m/%y, %H:%M')\n",
        "\n",
        "    gap_seconds = (current_time - previous_time).total_seconds()\n",
        "\n",
        "    # ignoring negative gaps and overnight gaps\n",
        "    if gap_seconds < 0:\n",
        "        continue\n",
        "    if gap_seconds > 86400:\n",
        "        continue\n",
        "\n",
        "    response_gaps[current_msg['sender']].append(gap_seconds)\n",
        "\n",
        "# calculating average response time for each person\n",
        "avg_response = {}\n",
        "for sender in sorted_senders:\n",
        "    gaps = response_gaps[sender]\n",
        "    if len(gaps) == 0:\n",
        "        avg_response[sender] = 999999\n",
        "    else:\n",
        "        total_gap = 0\n",
        "        for g in gaps:\n",
        "            total_gap = total_gap + g\n",
        "        avg_response[sender] = total_gap / len(gaps)\n",
        "\n",
        "# finding who replies fastest and slowest\n",
        "fastest_sender = sorted_senders[0]\n",
        "for sender in sorted_senders:\n",
        "    if avg_response[sender] < avg_response[fastest_sender]:\n",
        "        fastest_sender = sender\n",
        "\n",
        "slowest_sender = sorted_senders[0]\n",
        "for sender in sorted_senders:\n",
        "    if avg_response[sender] > avg_response[slowest_sender]:\n",
        "        slowest_sender = sender\n",
        "\n",
        "# helper function to make seconds look nice\n",
        "def seconds_to_readable(secs):\n",
        "    if secs < 60:\n",
        "        return str(round(secs)) + ' seconds'\n",
        "    elif secs < 3600:\n",
        "        return str(round(secs / 60, 1)) + ' minutes'\n",
        "    else:\n",
        "        return str(round(secs / 3600, 1)) + ' hours'\n",
        "\n",
        "# finding which days each person was active\n",
